    <light name="main_light" pos="0 0 1.4" dir="0 0 -1" directional="true" diffuse="0.8 0.8 0.8"/>
    <light name="fill_light" pos="0.5 -0.6 0.8" dir="-0.5 0.5 -1" diffuse="0.4 0.4 0.4"/>
